# =========================
# Backend (.env na raiz)
# =========================

# Ambiente da API
NODE_ENV=development
PORT=3000

# Banco de dados (Prisma)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/food
JWT_SECRET=your_jwt_secret


# Mercado Pago (obrigatorio para rotas de pagamento)
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-SEU_ACCESS_TOKEN
MERCADO_PAGO_PUBLIC_KEY=APP_USR-SEU_PUBLIC_KEY

# Integracao WhatsApp (opcional; hoje o servico esta em modo simulacao)
# EVOLUTION_API_URL=http://localhost:8080
# EVOLUTION_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_NUMBER=whatsapp:+5511999999999

# =========================
# Frontend Expo (front/.env)
# =========================

# URL da API com /api no final
# Exemplo para celular na mesma rede: http://192.168.1.100:3000/api
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# URL base do websocket (sem /api)
EXPO_PUBLIC_WS_URL=http://localhost:3000

# Google Maps (opcional; sem chave usa fallback Nominatim)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
